# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
BASE_URL=http://localhost:5000

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string
JWT_EXPIRE=30d

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_

# ─── Email (SMTP fallback) ────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=                  # Gmail: use App Password, not your real password
SMTP_FROM_NAME=SafiriPro
EMAIL_FROM=SafiriPro <noreply@yourdomain.com>

# ─── Cloudinary (file uploads) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Anthropic / Claude AI ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-

# ─── Pexels (stock photo search in quote builder) ─────────────────────────────
# Get a free API key at https://www.pexels.com/api/
PEXELS_API_KEY=

# ─── WhatsApp (Meta Cloud API) ────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=

# ─── Redis / BullMQ (Upstash recommended on Render free tier) ─────────────────
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=true

# ─── Paystack billing ─────────────────────────────────────────────────────────
# Get these from https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_               # Use sk_live_ in production
PAYSTACK_PUBLIC_KEY=pk_test_               # Used on the frontend
PAYSTACK_WEBHOOK_SECRET=                   # Webhook secret from Paystack dashboard

# Create these plans in the Paystack dashboard first (no trial). Monthly = standard interval,
# annual = "annually" interval at 10× the monthly price (2 months free).
PAYSTACK_PLAN_STARTER=PLN_                 # KES 2,499/month
PAYSTACK_PLAN_STARTER_ANNUAL=PLN_          # KES 24,990/year
PAYSTACK_PLAN_PRO=PLN_                     # KES 6,999/month
PAYSTACK_PLAN_PRO_ANNUAL=PLN_              # KES 69,990/year
PAYSTACK_PLAN_BUSINESS=PLN_                # KES 17,999/month
PAYSTACK_PLAN_BUSINESS_ANNUAL=PLN_         # KES 179,990/year
# Enterprise is sales-led — no self-serve checkout. Plan codes only needed if you
# want the cron downgrade path to support it (most won't).
PAYSTACK_PLAN_ENTERPRISE=
PAYSTACK_PLAN_ENTERPRISE_ANNUAL=

# Where Paystack sends the user after payment (server-side redirect to verify)
BILLING_CALLBACK_URL=https://your-api.onrender.com/api/billing/callback

# ─── Cron jobs (via cron-job.org) ─────────────────────────────────────────────
# Send this in X-Cron-Secret header from cron-job.org
CRON_SECRET=generate-a-random-string-here
